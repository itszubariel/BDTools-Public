{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "strict": false,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "noEmitOnError": false,
    "noImplicitAny": false,
    "outDir": "./dist"
  },
  "include": [
    "docs/*.ts",
    "tools/ts/src/**/*.ts",
    "tools/ts/bot-guild-list.ts",
    "tools/ts/container-builder.ts",
    "tools/ts/embed-builder.ts",
    "tools/ts/escaper.ts",
    "tools/ts/highlighter.ts",
    "tools/ts/indenter.ts",
    "tools/ts/permission-calc.ts",
    "tools/ts/send-embed-builder.ts"
  ]
}
